---
import { getCollection } from 'astro:content';

const usecases = await getCollection('usecases');
---

<section id="use-cases" class="relative z-10 bg-[#F8F1E9] max-w-7xl mx-auto px-6 py-16 md:py-20">
  <div class="text-center mb-12">
    <div class="modern-pill mb-3">FLEXIBLE &amp; SCALABLE</div>
    <h2 class="section-header tracking-tight">Built for multiple high-potential models</h2>
    <p class="mt-3 max-w-md mx-auto text-[#5C5C5C]">The friendly, direct nature of "wax my hair" works across consumer and professional applications.</p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {usecases.map((u) => (
      <div class="group bg-white border border-[#EDE4D7] hover:border-[#B85C38]/30 rounded-3xl p-8 transition-all">
        <div class="flex items-center gap-x-4 mb-5">
          <div class="text-[#B85C38]"><i class={`${u.data.icon} text-2xl`}></i></div>
          <h4 class="font-semibold text-lg">{u.data.title}</h4>
        </div>
        <p class="text-[#5C5C5C]">{u.data.description}</p>
      </div>
    ))}
  </div>
</section>
